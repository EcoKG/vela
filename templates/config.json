{
  "version": "1.0",
  "engine": "vela",
  "sandbox": {
    "enabled": true,
    "strict_mode": true,
    "bash_policy": "blocked"
  },
  "pipeline": {
    "default": "standard",
    "auto_scale": true,
    "enforce_all_steps": true
  },
  "gate_keeper": {
    "enabled": true,
    "default_mode": "read",
    "mode_auto_detect": true
  },
  "gate_guard": {
    "enabled": true,
    "hard_block_exit_code": 2,
    "bypass_allowed": false
  },
  "cli": {
    "language": null,
    "tools_dir": ".vela/cli"
  },
  "cache": {
    "enabled": true,
    "db_path": ".vela/cache/vela-cache.db",
    "treenode_enabled": true
  },
  "hooks": {
    "use_vela_hooks": true,
    "claude_code_trigger": true
  },
  "artifacts": {
    "base_dir": ".vela/artifacts",
    "date_format": "YYYY-MM-DD",
    "cleanup_after_hours": 24
  }
}
