{
  "version": "1.1",
  "pipelines": {
    "standard": {
      "description": "Full pipeline for all tasks",
      "steps": [
        {
          "id": "init",
          "name": "Initialize",
          "actor": "pm",
          "mode": "read",
          "entry_gate": [],
          "exit_gate": ["artifact_dir_created", "mode_detected", "git_clean"],
          "artifacts": [".vela/artifacts/{date}/{slug}/meta.json"],
          "max_revisions": 1
        },
        {
          "id": "research",
          "name": "Research & Analysis",
          "actor": "agent",
          "mode": "read",
          "entry_gate": ["init_complete"],
          "exit_gate": ["research_md_exists", "approval_exists"],
          "artifacts": ["research.md"],
          "max_revisions": 3,
          "treenode_cache": true,
          "team": {
            "worker_role": "researcher",
            "reviewer_role": "reviewer",
            "approver": "pm"
          }
        },
        {
          "id": "plan",
          "name": "Implementation Plan",
          "actor": "agent",
          "mode": "write",
          "entry_gate": ["research_md_exists"],
          "exit_gate": ["plan_md_exists", "plan_architecture_complete", "approval_exists"],
          "artifacts": ["plan.md"],
          "max_revisions": 3,
          "team": {
            "worker_role": "planner",
            "reviewer_role": "reviewer",
            "approver": "pm"
          },
          "architecture": {
            "required_sections": ["## Architecture", "## Class Specification", "## Test Strategy"],
            "min_section_bytes": 200
          }
        },
        {
          "id": "plan-check",
          "name": "Plan Verification",
          "actor": "agent",
          "mode": "read",
          "entry_gate": ["plan_md_exists"],
          "exit_gate": ["plan_check_pass"],
          "artifacts": ["plan-check.md"],
          "max_revisions": 2
        },
        {
          "id": "checkpoint",
          "name": "User Approval",
          "actor": "user",
          "mode": "read",
          "entry_gate": ["plan_check_pass"],
          "exit_gate": ["user_approved"],
          "artifacts": [],
          "max_revisions": 1
        },
        {
          "id": "branch",
          "name": "Branch Creation",
          "actor": "pm",
          "mode": "read",
          "entry_gate": ["user_approved"],
          "exit_gate": ["branch_created"],
          "artifacts": [],
          "max_revisions": 1,
          "skip_when": ["type in docs,analysis"],
          "git": {
            "modes": ["auto", "prompt", "none"],
            "default_mode": "auto",
            "prefix": "vela/",
            "protected_branches": ["main", "master", "develop"]
          }
        },
        {
          "id": "execute",
          "name": "Implementation",
          "actor": "agent",
          "mode": "readwrite",
          "entry_gate": ["branch_created"],
          "exit_gate": ["implementation_complete", "review_exists"],
          "artifacts": ["task-summary.md"],
          "max_revisions": 5,
          "sub_phases": ["test-write", "implement", "refactor"],
          "sub_phase_tracking": true,
          "team": {
            "worker_role": "executor",
            "reviewer_role": "reviewer",
            "approver": "pm"
          }
        },
        {
          "id": "verify",
          "name": "Verification",
          "actor": "agent",
          "mode": "read",
          "entry_gate": ["implementation_complete"],
          "exit_gate": ["verification_md_exists"],
          "artifacts": ["verification.md"],
          "max_revisions": 2
        },
        {
          "id": "commit",
          "name": "Commit Changes",
          "actor": "pm",
          "mode": "read",
          "entry_gate": ["verification_md_exists"],
          "exit_gate": ["changes_committed"],
          "artifacts": ["diff.patch"],
          "max_revisions": 1,
          "git": {
            "conventional_commits": true,
            "type_map": {
              "code": "feat",
              "code-bug": "fix",
              "code-refactor": "refactor",
              "docs": "docs",
              "infra": "chore",
              "analysis": "chore"
            },
            "include_pipeline_ref": true
          }
        },
        {
          "id": "finalize",
          "name": "Finalization",
          "actor": "pm",
          "mode": "write",
          "entry_gate": ["changes_committed"],
          "exit_gate": ["report_md_exists"],
          "artifacts": ["report.md"],
          "max_revisions": 1,
          "git": {
            "pr_mode": "prompt",
            "branch_cleanup_hint": true
          }
        }
      ]
    },
    "quick": {
      "description": "Simplified pipeline for small, clear tasks",
      "inherits": "standard",
      "steps_only": ["init", "plan", "execute", "verify", "commit", "finalize"],
      "conditions": {
        "max_files": 3,
        "max_lines": 100,
        "no_api_changes": true
      }
    },
    "ralph": {
      "description": "Auto-retry until tests pass. Iterate execute→verify until success.",
      "inherits": "standard",
      "steps_only": ["init", "execute", "verify", "commit", "finalize"],
      "overrides": {
        "execute": {
          "max_revisions": 10
        }
      },
      "ralph_mode": true,
      "max_iterations": 10
    },
    "trivial": {
      "description": "Minimal pipeline for single-line fixes",
      "inherits": "standard",
      "steps_only": ["init", "execute", "commit", "finalize"],
      "conditions": {
        "max_files": 1,
        "max_lines": 10
      },
      "overrides": {
        "execute": {
          "max_revisions": 1
        },
        "commit": {
          "exit_gate": []
        },
        "finalize": {
          "exit_gate": [],
          "artifacts": []
        }
      }
    },
    "hotfix": {
      "description": "Minimal pipeline for non-source changes (docs, config, readme). Skips review.",
      "inherits": "standard",
      "steps_only": ["init", "execute", "commit"],
      "overrides": {
        "execute": {
          "max_revisions": 1,
          "mode": "readwrite"
        },
        "commit": {
          "exit_gate": []
        }
      },
      "hotfix_mode": true
    }
  },
  "modes": {
    "read": {
      "allowed_tools": ["Read", "Glob", "Grep", "Agent"],
      "blocked_tools": ["Edit", "Write", "NotebookEdit"],
      "bash_policy": "read_only",
      "treenode_cache": true
    },
    "write": {
      "allowed_tools": ["Read", "Write", "Edit", "NotebookEdit", "Glob", "Grep"],
      "blocked_tools": [],
      "bash_policy": "blocked",
      "treenode_cache": false
    },
    "readwrite": {
      "allowed_tools": ["Read", "Write", "Edit", "NotebookEdit", "Glob", "Grep", "Agent"],
      "blocked_tools": [],
      "bash_policy": "restricted",
      "treenode_cache": true
    }
  },
  "scale_detection": {
    "small": {
      "max_files": 1,
      "max_lines": 50,
      "pipeline": "trivial"
    },
    "medium": {
      "max_files": 5,
      "max_lines": 300,
      "pipeline": "quick"
    },
    "large": {
      "min_files": 6,
      "min_lines": 300,
      "pipeline": "standard"
    }
  },
  "git": {
    "gitignore_entries": [
      ".vela/cache/",
      ".vela/state/",
      ".vela/artifacts/",
      ".vela/tracker-signals.json",
      ".vela/write-log.jsonl",
      "*.vela-tmp"
    ]
  }
}
