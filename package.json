{
  "name": "vela-cli",
  "version": "0.2.0",
  "type": "module",
  "description": "Vela — development governance CLI",
  "bin": {
    "vela": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "test -f dist/cli.js && (head -1 dist/cli.js | grep -q '^#!/' || sed -i '1i#!/usr/bin/env node' dist/cli.js) || true; rm -rf dist/hooks && cp -r src/hooks dist/hooks; rm -rf dist/agents && cp -r src/agents dist/agents",
    "test": "vitest run",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@inkjs/ui": "^2.0.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "*"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ]
}
